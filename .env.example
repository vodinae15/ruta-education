# ============================================
# Application URLs (ОБЯЗАТЕЛЬНО для production)
# ============================================
# Базовый URL вашего приложения
# Для development: http://localhost:3000
# Для production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL для редиректа после авторизации через email
# Для development: http://localhost:3000/dashboard
# Для production: https://your-domain.com/dashboard
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# AI Services Configuration (ОПЦИОНАЛЬНО)
# ============================================
# OpenRouter API для адаптации контента
# Получите ключ на https://openrouter.ai/
OPENROUTER_API_KEY="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"
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Claude API (альтернатива OpenRouter)
CLAUDE_API_KEY=your_claude_key_here

# OpenAI API (для транскрибации видео, если используется)
OPENAI_API_KEY=

# Unsplash API (для поиска изображений, если используется)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# ============================================
# Server Configuration (для production)
# ============================================
# Порт для запуска Next.js сервера
PORT=3000
