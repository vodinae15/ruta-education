# ============================================
# Application URLs (ОБЯЗАТЕЛЬНО)
# ============================================
# Базовый URL вашего приложения в production
# ЗАМЕНИТЕ на ваш реальный домен!
NEXT_PUBLIC_APP_URL=https://rutaedve.beget.tech

# URL для редиректа после авторизации через email
# Должен совпадать с настройками в Supabase Dashboard -> Authentication -> URL Configuration
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=https://rutaedve.beget.tech/dashboard

# ============================================
# Node Environment
# ============================================
NODE_ENV=production

# ============================================
# AI Services Configuration (ОПЦИОНАЛЬНО)
# ============================================
# OpenRouter API для адаптации контента
# Получите ключ на https://openrouter.ai/
OPENROUTER_API_KEY="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"
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Claude API (альтернатива OpenRouter)
CLAUDE_API_KEY=your_claude_key_here

# OpenAI API (для транскрибации видео, если используется)
OPENAI_API_KEY=

# Unsplash API (для поиска изображений, если используется)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=

# ============================================
# Server Configuration
# ============================================
# Порт для запуска Next.js сервера
# Обычно 3000, но может быть изменен в зависимости от настроек Nginx
PORT=3000

# ============================================
# ВАЖНО: После настройки переменных
# ============================================
# 1. Убедитесь, что NEXT_PUBLIC_APP_URL совпадает с вашим доменом
# 2. Добавьте URL в Supabase Dashboard:
#    - Authentication -> URL Configuration -> Redirect URLs
#    - Добавьте: https://rutaedve.beget.tech/dashboard
#    - Добавьте: https://rutaedve.beget.tech/student-dashboard
# 3. Проверьте настройки CORS в Supabase Dashboard
# 4. Запустите скрипт проверки: node scripts/check-env.js --production
